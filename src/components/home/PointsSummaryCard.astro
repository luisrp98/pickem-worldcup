---
import ShadowContainer from '../ShadowContainer.astro';

export interface Props {
  points?: number;
  href?: string;
  linkLabel?: string;
}

const { points = 0, href = '/clasificacion', linkLabel = 'Ver tabla' } = Astro.props;
---

<ShadowContainer>
  <div class="flex flex-col gap-3 p-2">
    <h2 class="text-lg font-semibold">Tus puntos</h2>
    <span class="text-5xl font-bold leading-none tabular-nums">{points} pts</span>
    <div class="flex justify-end">
      <a href={href} class="text-xs font-semibold tracking-wider uppercase hover:underline">
        {linkLabel} &gt;
      </a>
    </div>
  </div>
</ShadowContainer>
