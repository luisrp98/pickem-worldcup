---
import ShadowContainer from '../ShadowContainer.astro';

export interface PointsStats {
  points: number;
  correctResults: number;
  correctScores: number;
  position: number | null;
}

export interface Props {
  stats: PointsStats;
  href?: string;
  linkLabel?: string;
}

const { stats, href = '/clasificacion', linkLabel = 'Ver tabla' } = Astro.props;
---

<ShadowContainer bgClass="bg-arceus-accent-300 border border-arceus-accent-200">
  <div class="flex flex-col p-4 w-full gap-4 md:flex-row md:gap-0">
    <div class="flex flex-col w-full md:w-1/2">
      <h2 class="text-lg font-semibold">Tus puntos:</h2>
      <span class="text-4xl md:text-5xl font-bold leading-none tabular-nums">{stats.points} pts</span>
    </div>
    <div class="grid grid-cols-2 grid-rows-[1fr_auto] w-full md:w-1/2">
      <div class="flex flex-col">
        <span class="text-xs md:text-base font-semibold tracking-widest uppercase"> Resultados acertados:</span>
        <span class="text-2xl md:text-3xl font-bold tabular-nums">{stats.correctResults}</span>
      </div>
      <div class="flex flex-col">
        <span class="text-xs md:text-base font-semibold tracking-widest uppercase"> Marcadores acertados:</span>
        <span class="text-2xl md:text-3xl font-bold tabular-nums">{stats.correctScores}</span>
      </div>
      <div class="col-start-2 justify-self-end">
        <a href={href} class="text-xs font-semibold tracking-wider uppercase hover:underline block">
          {linkLabel} >
        </a>
      </div>
    </div>
  </div>
</ShadowContainer>
