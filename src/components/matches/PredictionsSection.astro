---
import type { Match, Prediction } from '../../lib/matches';
import MatchdayAccordion from './MatchdayAccordion.astro';

export interface MatchDay {
  dateISO: string;
  dayNumber: number;
  matches: Match[];
}

export interface Props {
  label: string;
  subtitle?: string;
  defaultOpen: boolean;
  matchDays: MatchDay[];
  predictions?: Record<string, Prediction>;
  readOnly?: boolean;
  emptyMessage?: string;
  bare?: boolean;
}

const {
  label,
  subtitle,
  defaultOpen,
  matchDays,
  predictions = {},
  readOnly = false,
  emptyMessage,
  bare = false,
} = Astro.props;

const panelId = `section-panel-${label.toLowerCase().replace(/\s+/g, '-')}`;
const isEmpty = matchDays.length === 0;
---

<section class="flex flex-col gap-3" data-section>
  <div
    class:list={[
      bare ? 'overflow-hidden' : 'rounded-md overflow-hidden bg-surface border border-border hover:border-border-strong transition-colors',
    ]}
  >
    <button
      type="button"
      class:list={[
        'w-full flex items-center justify-between gap-4 px-5 py-4 text-left cursor-pointer border-b border-border/60',
        !bare && 'hover:bg-arceus-accent-100/40 transition-colors',
      ]}
      data-section-trigger
      aria-expanded={defaultOpen ? 'true' : 'false'}
      aria-controls={panelId}
    >
      <div class="flex flex-col gap-0.5 min-w-0">
        <span class="text-xl md:text-2xl font-bold leading-tight tracking-wide truncate">{label}</span>
        {
          subtitle && (
            <span class="text-xs font-semibold tracking-widest uppercase text-text-tertiary">
              {subtitle}
            </span>
          )
        }
      </div>
      <span
        class:list={[
          'shrink-0 size-9 flex items-center justify-center rounded-sm bg-muted text-text-secondary transition-transform duration-300',
          defaultOpen && 'rotate-180',
        ]}
        data-section-icon
        aria-hidden="true"
      >
        <svg
          class="size-4"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m6 9 6 6 6-6"></path>
        </svg>
      </span>
    </button>
    <div
      id={panelId}
      class:list={[
        'grid transition-[grid-template-rows] duration-300 ease-out',
        defaultOpen ? 'grid-rows-[1fr]' : 'grid-rows-[0fr]',
      ]}
      data-section-panel
    >
      <div class="overflow-hidden">
        <div class="px-5 pb-4 pt-2">
          {
            isEmpty ? (
              <p class="text-sm text-text-tertiary py-6 text-center">{emptyMessage}</p>
            ) : (
              <div
                class="flex flex-col gap-3"
                data-accordion
                data-readonly={readOnly ? 'true' : undefined}
              >
                {matchDays.map((day) => (
                  <MatchdayAccordion
                    dateISO={day.dateISO}
                    dayNumber={day.dayNumber}
                    matches={day.matches}
                    predictions={predictions}
                    readOnly={readOnly}
                  />
                ))}
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function mountSectionToggles(): void {
    const sections = document.querySelectorAll<HTMLElement>('[data-section]');
    sections.forEach((section) => {
      const trigger = section.querySelector<HTMLButtonElement>('[data-section-trigger]');
      const panel = section.querySelector<HTMLElement>('[data-section-panel]');
      const icon = section.querySelector<HTMLElement>('[data-section-icon]');
      if (!trigger || !panel) return;

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          trigger.setAttribute('aria-expanded', 'false');
          panel.style.gridTemplateRows = '0fr';
          icon?.classList.remove('rotate-180');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          panel.style.gridTemplateRows = '1fr';
          icon?.classList.add('rotate-180');
        }
      });
    });
  }

  mountSectionToggles();
</script>
