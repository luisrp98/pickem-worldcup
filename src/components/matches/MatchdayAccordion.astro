---
import type { Match, Prediction } from '../../lib/matches';
import { formatMatchdayDate } from '../../lib/matches';
import MatchCard from './MatchCard.astro';
import Countdown from '../home/Countdown.astro';

export interface Props {
  dateISO: string;
  dayNumber: number;
  matches: Match[];
  predictions?: Record<string, Prediction>;
  readOnly?: boolean;
  label?: string;
  subtitle?: string;
  countdownTargetISO?: string;
}

const {
  dateISO,
  dayNumber,
  matches,
  predictions = {},
  readOnly = false,
  label,
  subtitle,
  countdownTargetISO,
} = Astro.props;

const panelId = `day-panel-${dateISO}`;
const formattedDate = formatMatchdayDate(dateISO);
const title = label ?? formattedDate;
const subtitleText = subtitle ?? `Día ${dayNumber} de la fase de grupos`;
---

<section
  class="bg-surface border border-border rounded-md overflow-hidden hover:border-border-strong transition-colors"
  data-accordion-item
  data-day-date={dateISO}
  data-readonly={readOnly ? 'true' : undefined}
>
  <button
    type="button"
    class="w-full flex items-center justify-between gap-4 px-5 py-4 text-left cursor-pointer"
    aria-expanded="false"
    aria-controls={panelId}
    data-accordion-trigger
  >
    <div class="flex flex-col gap-0.5 min-w-0">
      <span class="text-xl md:text-2xl font-bold leading-tight tracking-wide truncate">{title}</span>
      <span class="text-xs font-semibold tracking-widest uppercase text-text-tertiary">
        {subtitleText}
      </span>
    </div>
    {
      countdownTargetISO && (
        <Countdown
          targetISO={countdownTargetISO}
          class="hidden sm:block ml-auto text-sm font-medium text-text-secondary shrink-0"
        />
      )
    }
    <span
      class="shrink-0 size-9 flex items-center justify-center rounded-sm bg-muted text-text-secondary transition-transform duration-300"
      data-accordion-icon
      aria-hidden="true"
    >
      <svg
        class="size-4"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </span>
  </button>
  <div
    id={panelId}
    class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-out"
    data-accordion-panel
  >
    <div class="overflow-hidden">
      <div class="px-5 pb-2 divide-y divide-border/60">
        {matches.map((match) => <MatchCard match={match} prediction={predictions[match.id] ?? null} readOnly={readOnly} />)}
      </div>
      {
        !readOnly && (
          <div class="px-5 pb-4 pt-2 flex items-center justify-end gap-3" data-day-actions>
            <span class="text-xs text-text-tertiary hidden" data-save-status aria-live="polite"></span>
            <button
              type="button"
              class="text-xs font-semibold tracking-wider uppercase px-4 py-2 rounded-sm bg-arceus-secondary-950 text-arceus-primary-50 hover:bg-arceus-secondary-800 transition-colors disabled:opacity-40 disabled:cursor-not-allowed disabled:hover:bg-arceus-secondary-950"
              data-save-day
              disabled
            >
              Guardar día
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>
