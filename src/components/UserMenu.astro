---
export interface Props {
  email: string;
}

const { email } = Astro.props;

function initialsFromEmail(e: string): string {
  const local = e.split('@')[0] ?? e;
  const parts = local.split(/[._-]+/).filter(Boolean);
  if (parts.length >= 2) {
    return (parts[0][0] + parts[1][0]).toUpperCase();
  }
  return local.slice(0, 2).toUpperCase();
}

const initials = initialsFromEmail(email);
---

<details class="relative group" data-user-menu>
  <summary
    class="list-none cursor-pointer flex items-center gap-2 px-2 py-1 rounded-sm hover:bg-muted transition-colors [&::-webkit-details-marker]:hidden"
    aria-label="Menú de usuario"
  >
    <span
      class="w-8 h-8 rounded-full bg-arceus-secondary-950 text-arceus-primary-50 flex items-center justify-center text-xs font-semibold shrink-0"
    >
      {initials}
    </span>
    <span class="hidden sm:inline text-xs font-medium text-text-secondary max-w-32 truncate">
      {email}
    </span>
    <svg
      class="hidden sm:block size-3 text-text-tertiary transition-transform group-open:rotate-180"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="m6 9 6 6 6-6"></path>
    </svg>
  </summary>

  <div
    class="absolute right-0 top-full mt-2 min-w-56 bg-surface border border-border rounded-md shadow-lg z-30 p-3 flex flex-col gap-2"
    role="menu"
  >
    <p class="text-xs text-text-tertiary px-2 pt-1 break-all" data-user-email>
      {email}
    </p>
    <hr class="border-border" />
    <form method="POST" action="/logout">
      <button
        type="submit"
        class="w-full text-left px-2 py-2 text-xs font-semibold tracking-widest uppercase text-text hover:text-text-hover-primary hover:bg-muted rounded-sm transition-colors cursor-pointer"
        role="menuitem"
      >
        Cerrar sesión
      </button>
    </form>
  </div>
</details>

<script>
  function closeOnOutsideClick(e: MouseEvent) {
    const open = document.querySelectorAll<HTMLElement>('details[data-user-menu][open]');
    open.forEach((d) => {
      if (!d.contains(e.target as Node)) d.removeAttribute('open');
    });
  }
  if (typeof window !== 'undefined') {
    document.addEventListener('click', closeOnOutsideClick);
  }
</script>
