---
import type { CrystalBallInputType, CrystalBallOption } from '../../data/crystalBallQuestions';
import ShadowContainer from '../ShadowContainer.astro';

export interface Props {
  id: string;
  emoji: string;
  question: string;
  inputType: CrystalBallInputType;
  value?: string;
  options?: CrystalBallOption[];
  placeholder?: string;
  disabled?: boolean;
  name?: string;
  officialValue?: string | null;
  points?: number | null;
  maxPointsLabel?: string;
  bgClass?: string;
  circleBgClass?: string;
}

const {
  id,
  emoji,
  question,
  inputType,
  value = '',
  options = [],
  placeholder,
  disabled = false,
  name,
  officialValue = null,
  points = null,
  maxPointsLabel,
  bgClass = 'bg-arceus-accent-300 border border-arceus-accent-200',
  circleBgClass = 'bg-arceus-accent-100',
} = Astro.props;

const fieldName = name ?? `cb-${id}`;
const inputId = `cb-input-${id}`;

const inputClass =
  'w-full px-3 py-2 text-base border border-border rounded-sm bg-white text-text outline-none focus:border-text focus:bg-surface transition-[border-color,background] placeholder:text-text-tertiary disabled:bg-muted disabled:opacity-60 disabled:cursor-not-allowed';

const isScored = points !== null;

let badgeClass = '';
let badgeText = '';
let statusText = '';
let statusClass = '';

if (isScored && points > 0) {
  badgeClass = 'bg-green-500 text-white';
  badgeText = `+${points}`;
  statusText = 'Acertaste';
  statusClass = 'text-green-700';
} else if (isScored && points === 0) {
  badgeClass = 'bg-red-500 text-white';
  badgeText = '0';
  statusText = 'Fallaste';
  statusClass = 'text-red-700';
} else {
  badgeClass = 'bg-arceus-accent-300 text-text';
  badgeText = '—';
  statusText = 'Pendiente de puntos';
  statusClass = 'text-text-secondary';
}
---

<ShadowContainer bgClass={bgClass} class="p-6 flex flex-col">
  <header class="flex flex-col items-center text-center gap-2.5 mb-4">
    <span
      class:list={['w-14 h-14 rounded-full text-2xl flex items-center justify-center', circleBgClass]}
      aria-hidden="true"
    >
      {emoji}
    </span>
    <h3 class="text-lg md:text-xl font-bold leading-tight">
      {question}
    </h3>
  </header>
  <div class="flex-1">
    {
      inputType === 'select' ? (
        <select id={inputId} name={fieldName} disabled={disabled} aria-label={question} class={inputClass}>
          <option value="" disabled selected={value === ''}>
            Selecciona una opción
          </option>
          {options.map((opt) => (
            <option value={opt.value} selected={opt.value === value}>
              {opt.label}
            </option>
          ))}
        </select>
      ) : inputType === 'team' ? (
        <select id={inputId} name={fieldName} disabled={disabled} aria-label={question} class={inputClass}>
          <option value="" disabled selected={value === ''}>
            Selecciona un equipo
          </option>
          {options.map((opt) => (
            <option value={opt.value} selected={opt.value === value}>
              {opt.label}
            </option>
          ))}
        </select>
      ) : (
        <input
          id={inputId}
          name={fieldName}
          type="text"
          value={value}
          disabled={disabled}
          placeholder={placeholder ?? (inputType === 'player' ? 'Nombre del jugador' : 'Tu respuesta')}
          aria-label={question}
          class={inputClass}
        />
      )
    }
  </div>
  <div class="mt-4 flex items-center justify-between gap-2 shrink-0">
    {maxPointsLabel && (
      <span class="text-xs font-semibold tracking-wider uppercase text-text whitespace-nowrap">
        {maxPointsLabel}
      </span>
    )}
    <div class="flex items-center gap-2 ml-auto">
      <span
        class:list={['text-xs font-semibold tracking-wider uppercase px-2 py-1 rounded-sm whitespace-nowrap', badgeClass]}
      >
        {badgeText}
      </span>
      <span class:list={['text-xs font-semibold whitespace-nowrap', statusClass]}>
        {statusText}
      </span>
    </div>
  </div>
</ShadowContainer>
