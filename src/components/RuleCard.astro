---
export interface Props {
  number: number;
  title: string;
  class?: string;
}

const { number, title, class: className } = Astro.props;
---

<article
  class:list={[
    'bg-surface border border-border rounded-md p-6 hover:border-border-strong transition-colors flex flex-col',
    className,
  ]}
>
  <header class="flex flex-col items-center text-center gap-2.5 mb-4">
    <span
      class="w-10 h-10 rounded-md bg-arceus-accent-400 text-arceus-secondary-950 font-bold text-base flex items-center justify-center"
    >
      {number}
    </span>
    <h2 class="text-xl md:text-2xl font-bold leading-tight">{title}</h2>
  </header>
  <div class="text-sm text-text-secondary flex-1">
    <slot />
  </div>
</article>
