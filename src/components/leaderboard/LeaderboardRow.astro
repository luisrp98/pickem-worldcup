---
import type { LeaderboardEntry } from '../../data/leaderboard';
import PositionBadge from './PositionBadge.astro';
import PositionChangeIndicator from './PositionChangeIndicator.astro';
import Avatar from './Avatar.astro';
import { initialsFromName } from '../../lib/displayName';

export interface Props {
  entry: LeaderboardEntry;
  currentUserUid?: string;
}

const { entry, currentUserUid } = Astro.props;

const tdBase = 'px-5 py-3.5 border-b border-border text-sm';

const podiumBg =
  entry.currentPosition === 1
    ? 'bg-gold/10'
    : entry.currentPosition === 2
      ? 'bg-silver/10'
      : entry.currentPosition === 3
        ? 'bg-bronze/10'
        : '';

const podiumBorder =
  entry.currentPosition === 1
    ? 'border-l-4 border-gold'
    : entry.currentPosition === 2
      ? 'border-l-4 border-silver'
      : entry.currentPosition === 3
        ? 'border-l-4 border-bronze'
        : '';

const initials = initialsFromName(entry.displayName);

const isSelf = Boolean(currentUserUid) && entry.uid === currentUserUid;
const nameLinkClass = isSelf
  ? 'inline-block font-semibold text-text rounded-sm ring-1 ring-arceus-accent-500/60 px-1.5 py-0.5 hover:underline hover:text-text-hover-primary transition-colors'
  : 'font-semibold text-text hover:underline hover:text-text-hover-primary transition-colors';
---

<tr class:list={[podiumBg, podiumBorder]} data-self={isSelf ? 'true' : undefined}>
  <td class={tdBase}>
    <PositionBadge pos={entry.currentPosition} />
  </td>
  <td class={`${tdBase} max-sm:hidden`}>
    <PositionChangeIndicator current={entry.currentPosition} previous={entry.previousPosition} />
  </td>
  <td class={tdBase}>
    <Avatar initials={initials} />
  </td>
  <td class={tdBase}>
    <a href={`/predicciones?uid=${entry.uid}`} class={nameLinkClass}>
      {entry.displayName}
    </a>
  </td>
  <td class={`${tdBase} max-sm:hidden`}>
    <span class="font-medium text-text">{entry.correctResults}</span>
  </td>
  <td class={`${tdBase} max-sm:hidden`}>
    <span class="font-medium text-text">{entry.correctScores}</span>
  </td>
  <td class={tdBase}>
    <span class="font-bold text-base text-text">{entry.points}</span>
  </td>
</tr>
