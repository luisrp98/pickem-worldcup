---
export type LeaderboardPhase = 'total' | 'groups' | 'knockouts' | 'crystal-ball';

export interface Props {
  current: LeaderboardPhase;
}

const { current } = Astro.props;

const tabs: Array<{ id: LeaderboardPhase; label: string; href: string }> = [
  { id: 'total',       label: 'Total',         href: '/clasificacion?phase=total' },
  { id: 'groups',      label: 'Grupos',        href: '/clasificacion?phase=groups' },
  { id: 'knockouts',   label: 'Eliminatorias', href: '/clasificacion?phase=knockouts' },
  { id: 'crystal-ball', label: 'Bola de Cristal', href: '/clasificacion?phase=crystal-ball' },
];
---

<nav
  class="flex items-center gap-1 sm:gap-2 border-b border-border"
  aria-label="Secciones de clasificación"
>
  {
    tabs.map((tab) => {
      const isActive = tab.id === current;
      return (
        <a
          href={tab.href}
          aria-current={isActive ? 'page' : undefined}
          class:list={[
            'px-3 sm:px-4 py-2.5 text-xs sm:text-sm font-semibold tracking-widest uppercase transition-colors relative',
            isActive
              ? 'text-text-primary'
              : 'text-text-secondary hover:text-text-hover-primary',
          ]}
        >
          {tab.label}
          {isActive && (
            <span
              class="absolute left-3 right-3 sm:left-4 sm:right-4 -bottom-px h-0.5 bg-arceus-accent-500"
              aria-hidden="true"
            />
          )}
        </a>
      );
    })
  }
</nav>
