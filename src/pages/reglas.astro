---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ShadowContainer from '../components/ShadowContainer.astro';
import RuleCard from '../components/RuleCard.astro';
import PointsTable from '../components/PointsTable.astro';
import BulletList from '../components/BulletList.astro';
import {
  knockoutRounds,
  knockoutBonus,
  specialPredictions,
  considerations,
} from '../data/rules';
---

<Layout
  title="Reglas — PICKEM"
  description="Conoce las reglas del PICKEM: puntaje, plazos, bonificaciones y todo lo que necesitas saber para competir entre amigos."
>
  <div class="max-w-300 mx-auto px-6 md:px-8 py-8 md:py-12">
    <PageHeader eyebrow="Reglas del juego" title="¿Cómo se puntúa?" highlight="puntúa">
      <Fragment slot="description">
        Todo lo que necesitas saber para competir en el PICKEM. Léelas con calma, arma tu estrategia y que gane el
        mejor. <span aria-hidden="true">⏱</span>
      </Fragment>
    </PageHeader>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <RuleCard number={1} title="Cierre de predicciones" class="md:col-span-2">
        <p class="leading-relaxed">
          Las predicciones de cada partido se cierran
          <strong class="text-text font-semibold">10 minutos antes del inicio oficial</strong> del encuentro. Después de eso,
          no se aceptan cambios. <span aria-hidden="true">⛔</span>
        </p>
      </RuleCard>

      <RuleCard number={2} title="Fase eliminatoria" class="md:col-span-2">
        <p class="mb-4 leading-relaxed">
          Las predicciones corresponden al resultado al finalizar los
          <strong class="text-text font-semibold">90 minutos reglamentarios</strong>.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          <div>
            <p class="text-[0.6875rem] font-semibold tracking-widest uppercase text-text-tertiary mb-2">
              Por resultado correcto
            </p>
            <PointsTable data={knockoutRounds} compact />
          </div>
          <div>
            <p class="text-[0.6875rem] font-semibold tracking-widest uppercase text-text-tertiary mb-2">
              Puntuación adicional
            </p>
            <PointsTable data={knockoutBonus} compact />
            <p class="text-xs text-text-tertiary mt-3 leading-relaxed">
              <span aria-hidden="true">🏅</span> A mayor ronda, mayor el riesgo… y mayor la recompensa.
            </p>
          </div>
        </div>
      </RuleCard>

      <RuleCard number={3} title="Predicciones especiales" class="md:col-span-2">
        <p class="mb-4">{specialPredictions.intro}</p>
        <PointsTable data={specialPredictions} />
      </RuleCard>
    </div>

    <div class="mt-6 md:mt-8">
      <ShadowContainer>
        <div class="flex items-start gap-4 p-3 text-text">
          <span
            class="shrink-0 w-10 h-10 rounded-md bg-arceus-secondary-950 text-arceus-primary-50 flex items-center justify-center text-lg"
            aria-hidden="true"
          >
            🏅
          </span>
          <div>
            <h2 class="text-lg md:text-xl font-bold mb-2">A tener en cuenta</h2>
            <BulletList items={considerations} markerClass="font-bold" class="text-sm space-y-1.5" />
          </div>
        </div>
      </ShadowContainer>
    </div>
  </div>
</Layout>
