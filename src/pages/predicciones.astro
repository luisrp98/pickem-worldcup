---
import Layout from '../layouts/Layout.astro';
import MatchdayAccordion from '../components/matches/MatchdayAccordion.astro';
import { fetchMatches, groupByDate } from '../lib/matches';
import { loadPredictions } from '../lib/server/predictions';

let matchesByDate: Map<string, import('../lib/matches').Match[]> = new Map();
let predictions: import('../lib/server/predictions').PredictionsMap = {};
let loadError = false;

try {
  const tournament = await fetchMatches();
  matchesByDate = groupByDate(tournament.matches);
  predictions = await loadPredictions(Astro.cookies);
} catch (err) {
  console.error('predicciones: load failed', err);
  loadError = true;
}

const dates = [...matchesByDate.keys()].sort();
---

<Layout
  title="Predicciones — PICKEM"
  description="Consulta y registra tus predicciones para los próximos partidos del mundial."
>
  <div class="max-w-300 mx-auto px-6 md:px-8 py-8 md:py-12">
    <header class="mb-8 md:mb-10">
      <div class="flex items-center gap-4 mb-4 pb-2 border-b border-border">
        <span class="text-xs font-semibold tracking-widest uppercase text-text-secondary"> Tus pronósticos </span>
        <span class="flex-1"></span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold leading-[1.1] tracking-wide mb-3">
        <span class="text-text-hover-primary">Predicciones</span> de la fase de grupos
      </h1>
      <p class="text-base text-text-secondary max-w-xl leading-relaxed">
        Tocá cada día para ver los partidos y registrar tu marcador. <span aria-hidden="true">⚽</span>
      </p>
    </header>

    {
      loadError ? (
        <p class="text-sm text-text-tertiary py-8 text-center">
          No se pudieron cargar los partidos. Reintentá en unos minutos.
        </p>
      ) : dates.length === 0 ? (
        <p class="text-sm text-text-tertiary py-8 text-center">No hay partidos disponibles.</p>
      ) : (
        <div class="flex flex-col gap-3" data-accordion>
          {dates.map((dateISO, idx) => (
            <MatchdayAccordion
              dateISO={dateISO}
              dayNumber={idx + 1}
              matches={matchesByDate.get(dateISO) ?? []}
              predictions={predictions}
            />
          ))}
        </div>
      )
    }
  </div>
</Layout>

<script>
  import { mountPredictionsController } from '../scripts/predictionsController';
  mountPredictionsController();
</script>
