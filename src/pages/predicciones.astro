---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Predicciones — PICKEM"
  description="Consulta y registra tus predicciones para los próximos partidos del mundial."
>
  <div class="max-w-300 mx-auto px-6 md:px-8 py-8 md:py-12">
    <header class="mb-8 md:mb-10">
      <div class="flex items-center gap-4 mb-4 pb-2 border-b border-border">
        <span class="text-xs font-semibold tracking-widest uppercase text-text-secondary"> Tus pronósticos </span>
        <span class="flex-1"></span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold leading-[1.1] tracking-wide mb-3">
        <span class="text-text-hover-primary">Predicciones</span> de la fase de grupos
      </h1>
      <p class="text-base text-text-secondary max-w-xl leading-relaxed">
        Tocá cada día para ver los partidos y registrar tu marcador. <span aria-hidden="true">⚽</span>
      </p>
    </header>

    <div class="flex flex-col gap-3" data-accordion>
      <p class="text-sm text-text-tertiary py-8 text-center" data-loading>Cargando partidos…</p>
    </div>
  </div>
</Layout>

<script>
  import {
    fetchMatches,
    getMatchStatus,
    groupByDate,
    renderMatchday,
    refreshMatchInDom,
    type Match,
    type Prediction,
  } from '../lib/matches';

  const POLL_MS = 5 * 60 * 1000;
  const PREDICTIONS_API = '/api/predictions/day';

  type PredictionsMap = Record<string, Prediction>;

  function renderAll(matches: Match[], predictions: PredictionsMap) {
    const container = document.querySelector<HTMLElement>('[data-accordion]');
    if (!container) return;
    const grouped = groupByDate(matches);
    const dates = [...grouped.keys()].sort();
    container.innerHTML = dates
      .map((date, idx) => renderMatchday(date, idx + 1, grouped.get(date) ?? [], predictions))
      .join('');
    attachSaveHandlers();
  }

  function updateAll(matches: Match[]) {
    for (const match of matches) {
      const status = getMatchStatus(match);
      if (status === 'live' || status === 'closed') {
        refreshMatchInDom(match);
      }
    }
  }

  async function fetchPredictions(): Promise<PredictionsMap> {
    try {
      const res = await fetch(PREDICTIONS_API, { cache: 'no-store' });
      if (!res.ok) return {};
      const data = (await res.json()) as { predictions: Record<string, Prediction> };
      const out: PredictionsMap = {};
      for (const [id, p] of Object.entries(data.predictions)) {
        if (typeof p.score1 === 'number' && typeof p.score2 === 'number') {
          out[id] = { score1: p.score1, score2: p.score2 };
        }
      }
      return out;
    } catch {
      return {};
    }
  }

  function readMatchInputsFromDom(item: HTMLElement): PredictionsMap {
    const out: PredictionsMap = {};
    const matches = item.querySelectorAll<HTMLElement>('[data-match-id]');
    for (const m of matches) {
      const id = m.dataset.matchId;
      if (!id) continue;
      const home = m.querySelector<HTMLInputElement>('[data-score-home]');
      const away = m.querySelector<HTMLInputElement>('[data-score-away]');
      if (!home || !away) continue;
      const score1 = parseInt(home.value, 10);
      const score2 = parseInt(away.value, 10);
      if (Number.isFinite(score1) && Number.isFinite(score2)) {
        out[id] = { score1, score2 };
      }
    }
    return out;
  }

  function markDayDirty(item: HTMLElement) {
    const indicator = item.querySelector<HTMLElement>('[data-dirty-indicator]');
    const status = item.querySelector<HTMLElement>('[data-save-status]');
    const btn = item.querySelector<HTMLButtonElement>('[data-save-day]');
    if (btn) btn.disabled = false;
    if (indicator) indicator.classList.remove('hidden');
    if (status) {
      status.textContent = 'Cambios sin guardar';
      status.classList.remove('hidden');
      status.classList.add('text-text-tertiary');
      status.classList.remove('text-arceus-accent-700');
    }
  }

  function markDayClean(item: HTMLElement) {
    const indicators = item.querySelectorAll<HTMLElement>('[data-dirty-indicator]');
    indicators.forEach((i) => i.classList.add('hidden'));
    const status = item.querySelector<HTMLElement>('[data-save-status]');
    const btn = item.querySelector<HTMLButtonElement>('[data-save-day]');
    if (status) {
      status.textContent = 'Guardado';
      status.classList.remove('hidden');
      status.classList.remove('text-text-tertiary');
      status.classList.add('text-arceus-accent-700');
      setTimeout(() => status.classList.add('hidden'), 2000);
    }
    if (btn) btn.disabled = true;
  }

  function attachSaveHandlers() {
    const items = document.querySelectorAll<HTMLElement>('[data-accordion-item]');
    items.forEach((item) => {
      const inputs = item.querySelectorAll<HTMLInputElement>('input[type="number"]');
      inputs.forEach((input) => {
        input.addEventListener('input', () => markDayDirty(item));
      });

      const btn = item.querySelector<HTMLButtonElement>('[data-save-day]');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        const date = item.dataset.dayDate;
        if (!date) return;
        const predictions = readMatchInputsFromDom(item);
        const arr = Object.entries(predictions).map(([matchId, p]) => ({
          matchId,
          score1: p.score1,
          score2: p.score2,
        }));
        btn.disabled = true;
        try {
          const res = await fetch(PREDICTIONS_API, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ date, predictions: arr }),
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          markDayClean(item);
        } catch (err) {
          console.error('save day failed', err);
          const status = item.querySelector<HTMLElement>('[data-save-status]');
          if (status) {
            status.textContent = 'Error al guardar';
            status.classList.remove('hidden');
          }
          btn.disabled = false;
        }
      });
    });
  }

  async function load() {
    try {
      const [data, predictions] = await Promise.all([fetchMatches(), fetchPredictions()]);
      renderAll(data.matches, predictions);
    } catch (err) {
      const container = document.querySelector<HTMLElement>('[data-accordion]');
      if (container) {
        container.innerHTML =
          '<p class="text-sm text-text-tertiary py-8 text-center">No se pudieron cargar los partidos. Reintentando…</p>';
      }
      console.error('load matches failed', err);
    }
  }

  async function refresh() {
    try {
      const data = await fetchMatches();
      const hasLive = data.matches.some((m) => getMatchStatus(m) === 'live');
      if (hasLive) updateAll(data.matches);
    } catch (err) {
      console.error('refresh matches failed', err);
    }
  }

  function initAccordion() {
    const accordions = document.querySelectorAll<HTMLElement>('[data-accordion]');
    accordions.forEach((accordion) => {
      accordion.addEventListener('click', (e) => {
        const target = e.target as HTMLElement;
        const trigger = target.closest<HTMLButtonElement>('[data-accordion-trigger]');
        if (!trigger || !accordion.contains(trigger)) return;

        const item = trigger.closest<HTMLElement>('[data-accordion-item]');
        if (!item) return;
        const panel = item.querySelector<HTMLElement>('[data-accordion-panel]');
        const icon = item.querySelector<HTMLElement>('[data-accordion-icon]');
        if (!panel) return;

        accordion.querySelectorAll<HTMLElement>('[data-accordion-item]').forEach((other) => {
          if (other === item) return;
          const t = other.querySelector<HTMLButtonElement>('[data-accordion-trigger]');
          const p = other.querySelector<HTMLElement>('[data-accordion-panel]');
          if (!t || !p) return;
          t.setAttribute('aria-expanded', 'false');
          p.style.gridTemplateRows = '0fr';
        });

        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        if (isOpen) {
          trigger.setAttribute('aria-expanded', 'false');
          panel.style.gridTemplateRows = '0fr';
          icon?.classList.remove('rotate-180');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          panel.style.gridTemplateRows = '1fr';
          icon?.classList.add('rotate-180');
        }
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initAccordion();
      load();
    });
  } else {
    initAccordion();
    load();
  }

  setInterval(refresh, POLL_MS);
</script>
