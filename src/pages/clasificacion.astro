---
import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import ShadowContainer from '../components/ShadowContainer.astro';
import LeaderboardTable from '../components/leaderboard/LeaderboardTable.astro';
import type { LeaderboardEntry } from '../data/leaderboard';
import { loadLeaderboard } from '../lib/server/leaderboard';

let entries: LeaderboardEntry[] = [];
let loadError = false;
const currentUserUid = Astro.locals.user?.uid;

try {
  entries = await loadLeaderboard(Astro.cookies);
} catch (err) {
  console.error('clasificacion: loadLeaderboard failed', err);
  loadError = true;
}
---

<Layout
  title="Clasificación — PICKEM"
  description="Consulta la clasificación actual de los participantes en PICKEM. Sigue tu posición y compite por el primer lugar."
>
  <div class="max-w-300 mx-auto px-6 md:px-8 py-8 md:py-12">
    <PageHeader eyebrow="Ranking" title="La clasificación del PICKEM" highlight="clasificación">
      <Fragment slot="description">
        Mirá cómo vas respecto al resto y peleá por el primer puesto. <span aria-hidden="true">🏆</span>
      </Fragment>
    </PageHeader>

    {
      loadError ? (
        <ShadowContainer bgClass="bg-white">
          <p class="text-sm text-text-tertiary py-8 text-center">
            No se pudo cargar la clasificación. Reintentá en unos minutos.
          </p>
        </ShadowContainer>
      ) : (
        <ShadowContainer bgClass="bg-white">
          <LeaderboardTable entries={entries} currentUserUid={currentUserUid} />
        </ShadowContainer>
      )
    }
  </div>
</Layout>
