---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import LoginForm from '../components/LoginForm.astro';
import { verifySession } from '../lib/firebase/session';

const user = await verifySession(Astro.cookies);
if (user) {
  return Astro.redirect(safeRedirectFromUrl(Astro.url));
}

const safeRedirect = safeRedirectFromUrl(Astro.url);

function safeRedirectFromUrl(url: URL): string {
  const raw = url.searchParams.get('from');
  if (!raw) return '/';
  if (!raw.startsWith('/') || raw.startsWith('//')) return '/';
  return raw;
}
---

<Layout
  title="Iniciar sesión — PICKEM"
  description="Iniciá sesión para registrar tus predicciones del mundial."
>
  <div class="max-w-md mx-auto pt-12 md:pt-20">
    <header class="mb-8 text-center">
      <h1 class="text-3xl md:text-4xl font-bold tracking-wide mb-2">
        Bienvenido a <span class="text-text-hover-primary">PICK'EM</span>
      </h1>
      <p class="text-sm text-text-secondary">Iniciá sesión con tu cuenta para continuar.</p>
    </header>

    <LoginForm from={safeRedirect} />
  </div>
</Layout>
