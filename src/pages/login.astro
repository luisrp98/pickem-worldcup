---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import PageHeader from '../components/PageHeader.astro';
import LoginForm from '../components/LoginForm.astro';
import { verifySession } from '../lib/firebase/session';

const user = await verifySession(Astro.cookies);
if (user) {
  return Astro.redirect(safeRedirectFromUrl(Astro.url));
}

const safeRedirect = safeRedirectFromUrl(Astro.url);

function safeRedirectFromUrl(url: URL): string {
  const raw = url.searchParams.get('from');
  if (!raw) return '/';
  if (!raw.startsWith('/') || raw.startsWith('//')) return '/';
  return raw;
}
---

<Layout title="Iniciar sesión — PICKEM" description="Iniciá sesión para registrar tus predicciones del mundial.">
  <div class="max-w-md mx-auto pt-12 md:pt-20">
    <PageHeader title="Bienvenido a PICK'EM" highlight="PICK'EM" centered>
      <Fragment slot="description">Iniciá sesión con tu cuenta para continuar.</Fragment>
    </PageHeader>

    <LoginForm from={safeRedirect} />
  </div>
</Layout>
