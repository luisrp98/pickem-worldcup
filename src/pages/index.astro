---
import Layout from '../layouts/Layout.astro';
import ShadowContainer from '../components/ShadowContainer.astro';

const user = Astro.locals.user!;
const friendlyName = user.email.split('@')[0] ?? user.email;
---

<Layout
  title="PICKEM — Predicciones Deportivas"
  description="Plataforma de predicciones deportivas. Registra tus pronósticos, consulta las reglas y sigue la clasificación."
>
  <div class="text-2xl font-bold text-center pt-8">
    <h1 class="">¡Hola {friendlyName}! 👋</h1>
  </div>
  <div class="flex flex-col gap-4">
    <ShadowContainer>
      <div class="flex flex-col gap-3 p-2">
        <div class="flex items-center justify-between">
          <h2>Proximos partidos</h2>
          <p data-countdown>—</p>
        </div>

        <hr class="border-t border-bg-secondary/40" />
        <div class="flex flex-col gap-2" data-upcoming>
          <p class="text-sm text-text-tertiary py-4 text-center" data-loading>Cargando…</p>
        </div>
      </div>
    </ShadowContainer>

    <ShadowContainer>
      <div class="flex flex-col gap-3 p-2">
        <h1>Tus puntos</h1>

        <span class="text-5xl font-bold leading-none tabular-nums">0 pts</span>

        <div class="flex justify-end">
          <a href="/clasificacion" class="text-xs font-semibold tracking-wider uppercase hover:underline">
            Ver tabla &gt;</a
          >
        </div>
      </div>
    </ShadowContainer>
  </div>
</Layout>

<script>
  // Phase 5/6 will add a controller here that fetches matches, renders
  // <UpcomingMatch> components in [data-upcoming], ticks the countdown in
  // [data-countdown], and polls every 5 min. For now, the static
  // placeholder above is shown.
</script>
