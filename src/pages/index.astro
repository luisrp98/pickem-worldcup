---
import Layout from '../layouts/Layout.astro';
import Greeting from '../components/home/Greeting.astro';
import UpcomingMatchesCard from '../components/home/UpcomingMatchesCard.astro';
import PointsSummaryCard from '../components/home/PointsSummaryCard.astro';
import { fetchMatches, getMatchStatus, parseKickoff } from '../lib/matches';

const UPCOMING_LIMIT = 3;

const user = Astro.locals.user!;
const friendlyName = user.email.split('@')[0] ?? user.email;

let upcoming: import('../lib/matches').Match[] = [];
let nextKickoffISO = '';
let loadError = false;

try {
  const tournament = await fetchMatches();
  const now = new Date();
  upcoming = tournament.matches
    .map((m) => ({ match: m, kickoff: parseKickoff(m) }))
    .filter(
      (x) => x.kickoff !== null && getMatchStatus(x.match, now) === 'pending' && x.kickoff.getTime() > now.getTime(),
    )
    .sort((a, b) => (a.kickoff as Date).getTime() - (b.kickoff as Date).getTime())
    .slice(0, UPCOMING_LIMIT)
    .map((x) => x.match);

  const nextKickoff = upcoming.length > 0 ? parseKickoff(upcoming[0]) : null;
  if (nextKickoff) {
    nextKickoffISO = nextKickoff.toISOString();
  }
} catch (err) {
  console.error('home: load failed', err);
  loadError = true;
}
---

<Layout
  title="PICKEM — Predicciones Deportivas"
  description="Plataforma de predicciones deportivas. Registra tus pronósticos, consulta las reglas y sigue la clasificación."
>
  <Greeting name={friendlyName} />
  <div class="flex flex-col gap-4">
    <UpcomingMatchesCard matches={upcoming} nextKickoffISO={nextKickoffISO} loadError={loadError} />
    <PointsSummaryCard points={0} />
  </div>
</Layout>

<script>
  import { mountHomeController } from '../scripts/homeController';
  mountHomeController();
</script>
