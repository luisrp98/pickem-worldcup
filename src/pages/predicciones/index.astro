---
import Layout from '../../layouts/Layout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ShadowContainer from '../../components/ShadowContainer.astro';
import PredictionsTabs from '../../components/predictions/PredictionsTabs.astro';
import PredictionsSection, { type MatchDay } from '../../components/matches/PredictionsSection.astro';
import { groupByDate, isGroupRound, splitByTime } from '../../lib/matches';
import { loadTournament } from '../../lib/sync';
import { loadPredictions } from '../../lib/server/predictions';
import { resolveDisplayName } from '../../lib/displayName';

const currentUser = Astro.locals.user;
const targetUid = Astro.url.searchParams.get('uid');

if (!currentUser && !targetUid) {
  return Astro.redirect('/login?from=' + encodeURIComponent('/predicciones'));
}

const isReadOnly = Boolean(targetUid) && targetUid !== currentUser?.uid;

let pastDays: MatchDay[] = [];
let upcomingDays: MatchDay[] = [];
let predictions: import('../../lib/server/predictions').PredictionsMap = {};
let loadError = false;
let pageTitle = 'Predicciones de grupos';
let layoutTitle = 'Predicciones — PICKEM';
let pageHighlight = 'Predicciones de grupos';
let showDescription = true;

try {
  const tournament = await loadTournament();
  const allDates = [...new Set(tournament.matches.map((m) => m.date))].sort();
  const dayNumberByDate = new Map(allDates.map((d, i) => [d, i + 1]));

  const groupMatches = tournament.matches.filter((m) => isGroupRound(m.group, m.round));
  const partition = splitByTime(groupMatches, new Date());
  const pastByDate = groupByDate(partition.past);
  const upcomingByDate = groupByDate(partition.upcoming);

  pastDays = [...pastByDate.entries()]
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([dateISO, matches]) => ({
      dateISO,
      dayNumber: dayNumberByDate.get(dateISO) ?? 0,
      matches,
    }));

  upcomingDays = [...upcomingByDate.entries()]
    .sort(([a], [b]) => a.localeCompare(b))
    .map(([dateISO, matches]) => ({
      dateISO,
      dayNumber: dayNumberByDate.get(dateISO) ?? 0,
      matches,
    }));

  if (isReadOnly && targetUid) {
    predictions = await loadPredictions(Astro.cookies, targetUid);
    const name = await resolveDisplayName(targetUid);
    pageTitle = `Predicciones de grupos de ${name}`;
    layoutTitle = `Predicciones de grupos de ${name} — PICKEM`;
    pageHighlight = 'Predicciones de grupos de';
    showDescription = false;
  } else if (currentUser) {
    predictions = await loadPredictions(Astro.cookies);
  }
} catch (err) {
  console.error('predicciones: load failed', err);
  loadError = true;
}

const hasAnyMatch = pastDays.length > 0 || upcomingDays.length > 0;
---

<Layout
  title={layoutTitle}
  description="Consulta y registra tus predicciones para los próximos partidos del mundial."
>
  <div class="max-w-300 mx-auto px-6 md:px-8 py-8 md:py-12">
    <PageHeader eyebrow="Tus pronósticos" title={pageTitle} highlight={pageHighlight}>
      {
        showDescription && (
          <Fragment slot="description">
            Toca cada día para ver los partidos y registrar tu marcador. <span aria-hidden="true">⚽</span>
          </Fragment>
        )
      }
    </PageHeader>

    <PredictionsTabs current="groups" />

    {
      loadError ? (
        <p class="text-sm text-text-tertiary py-8 text-center">
          No se pudieron cargar los partidos. Reintenta en unos minutos.
        </p>
      ) : !hasAnyMatch ? (
        <p class="text-sm text-text-tertiary py-8 text-center">No hay partidos disponibles.</p>
      ) : (
        <div class="flex flex-col gap-3">
          <ShadowContainer bgClass="bg-arceus-accent-100 border border-arceus-accent-200">
            <PredictionsSection
              label="Partidos pasados"
              defaultOpen={false}
              matchDays={pastDays}
              predictions={predictions}
              readOnly={isReadOnly}
              emptyMessage="Aún no hay partidos finalizados."
              bare
            />
          </ShadowContainer>
          <ShadowContainer bgClass="bg-arceus-accent-300 border border-arceus-accent-200">
            <PredictionsSection
              label="Próximos partidos"
              defaultOpen={true}
              matchDays={upcomingDays}
              predictions={predictions}
              readOnly={isReadOnly}
              emptyMessage="No hay partidos pendientes en este momento."
              bare
            />
          </ShadowContainer>
        </div>
      )
    }
  </div>
</Layout>

<script>
  import { mountPredictionsController } from '../../scripts/predictionsController';
  mountPredictionsController();
</script>
